{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Bakery products for sale"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "selling_price": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "specific_ingredients": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::ingredient.ingredient"
    }
  }
}
